rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(ownerId) { return isAuth() && ownerId == request.auth.uid; }

    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    match /forests/{forestId} {
      allow read, write: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /throws/{throwId} {
      allow read, write: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /observations/{observationId} {
      allow read, write: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /harvests/{harvestId} {
      allow read, write: if isOwner(resource.data.ownerId);
      allow create: if isOwner(request.resource.data.ownerId);
    }

    match /notifications/{notificationId} {
      allow read, write: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /{collection}/{docId} {
      allow read: if isAuth() && collection in ['podTypes', 'plants', 'growthModels', 'recipes'];
      allow write: if false;
    }
  }
}
